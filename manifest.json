{
  "manifest_version": 3,
  "name": "Audio Transcription & Live Interpreter",
  "version": "2.8.5",
  "description": "Real-time transcription, live translation, and speech-to-speech playback for any audio playing in your browser.",
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "tabCapture",
    "scripting",
    "tts"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://clients5.google.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  }
}
